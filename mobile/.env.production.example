# Production mobile build values.
# EXPO_PUBLIC_API_URL must include the /api suffix.
EXPO_PUBLIC_API_URL=https://kollector.example.com/api
EXPO_PUBLIC_SOCKET_URL=https://kollector.example.com

# Expo/EAS project metadata for app.config.js
EXPO_OWNER=your-expo-account
EXPO_PROJECT_ID=00000000-0000-0000-0000-000000000000
EXPO_ANDROID_PACKAGE=com.yourcompany.kollector
EXPO_IOS_BUNDLE_IDENTIFIER=com.yourcompany.kollector
