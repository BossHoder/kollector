  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "config:public": "expo config --type public",
    "doctor": "expo doctor",
    "build:android:preview": "npx eas-cli@latest build --platform android --profile preview",
    "build:ios:preview": "npx eas-cli@latest build --platform ios --profile preview",
    "build:android:production": "npx eas-cli@latest build --platform android --profile production",
    "build:ios:production": "npx eas-cli@latest build --platform ios --profile production",
    "build:all:production": "npx eas-cli@latest build --platform all --profile production",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.12.0",
    "@react-navigation/native": "^7.1.28",
    "@react-navigation/native-stack": "^7.12.0",
    "@shopify/react-native-skia": "2.2.12",
    "expo": "~54.0.29",
    "expo-camera": "~17.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-network": "~8.0.8",
    "expo-secure-store": "^15.0.8",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "^5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
