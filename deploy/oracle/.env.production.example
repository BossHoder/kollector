COMPOSE_PROJECT_NAME=kollector
EDGE_HTTP_PORT=8080
ENABLE_HOST_NGINX_CUTOVER=true

# Public IP or domain for the stack.
PUBLIC_BASE_URL=http://YOUR_VM_PUBLIC_IP
CLIENT_URL=http://YOUR_VM_PUBLIC_IP
CORS_ORIGIN=http://YOUR_VM_PUBLIC_IP
SOCKET_CORS_ORIGIN=http://YOUR_VM_PUBLIC_IP
STORAGE_PUBLIC_BASE_URL=http://YOUR_VM_PUBLIC_IP

# Shared storage and model cache inside containers.
STORAGE_DRIVER=local
STORAGE_ROOT=/var/lib/kollector/uploads
HF_HOME=/var/lib/kollector/hf-cache
U2NET_HOME=/var/lib/kollector/hf-cache/u2net

# App secrets and services.
MONGODB_URI=mongodb+srv://username:password@cluster0.example.mongodb.net/kollector
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# AI models.
MODEL_REMOVE_BG=briaai/RMBG-1.4
MODEL_REMOVE_BG_REVISION=
MODEL_VISION=vikhyatk/moondream2
MODEL_VISION_REVISION=
HF_TOKEN=
WARM_MODELS_REQUIRED=false

# Optional Cloudinary backward-compat mode.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
