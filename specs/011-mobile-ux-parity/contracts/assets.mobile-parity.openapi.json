{
  "openapi": "3.0.3",
  "info": {
    "title": "Kollector Assets API - Mobile UX Parity",
    "version": "0.2.0",
    "description": "Contract bundle for mobile parity fixes: canonical categories, resilient filtering, upload metadata hydration, retry, and realtime-aligned polling behavior."
  },
  "servers": [
    {
      "url": "http://localhost:4000"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "Category": {
        "type": "string",
        "enum": ["sneaker", "lego", "camera", "other"]
      },
      "Status": {
        "type": "string",
        "enum": ["draft", "processing", "partial", "active", "archived", "failed"]
      },
      "AssetFileMetadata": {
        "type": "object",
        "properties": {
          "originalFilename": { "type": "string" },
          "fileSizeMB": { "type": "number" },
          "mimeType": { "type": "string" },
          "uploadedAt": { "type": "string", "format": "date-time" }
        }
      },
      "Asset": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "userId": { "type": "string" },
          "category": { "$ref": "#/components/schemas/Category" },
          "status": { "$ref": "#/components/schemas/Status" },
          "images": {
            "type": "object",
            "properties": {
              "original": {
                "type": "object",
                "properties": {
                  "url": { "type": "string" }
                }
              },
              "processed": {
                "type": "object",
                "properties": {
                  "url": { "type": "string" }
                }
              },
              "thumbnail": {
                "type": "object",
                "properties": {
                  "url": { "type": "string" }
                }
              }
            }
          },
          "aiMetadata": {
            "type": "object"
          },
          "fileMetadata": {
            "$ref": "#/components/schemas/AssetFileMetadata"
          },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["id", "category", "status"]
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/api/assets": {
      "get": {
        "summary": "List user assets with cursor pagination and filters",
        "description": "Category must be canonical. Clients should normalize aliases before request; unknown category should fall back to All (omit query param).",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          },
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "$ref": "#/components/schemas/Status" }
          },
          {
            "name": "category",
            "in": "query",
            "required": false,
            "schema": { "$ref": "#/components/schemas/Category" }
          },
          {
            "name": "search",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "assets": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Asset" }
                    },
                    "pagination": {
                      "type": "object",
                      "properties": {
                        "nextCursor": { "type": "string", "nullable": true },
                        "hasMore": { "type": "boolean" },
                        "limit": { "type": "integer" }
                      }
                    }
                  },
                  "required": ["assets", "pagination"]
                }
              }
            }
          },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/assets/{id}": {
      "get": {
        "summary": "Get asset detail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "asset": { "$ref": "#/components/schemas/Asset" }
                  },
                  "required": ["asset"]
                }
              }
            }
          },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      },
      "patch": {
        "summary": "Update asset fields (including archive)",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": {
                    "type": "string",
                    "enum": ["draft", "processing", "partial", "active", "archived", "failed"]
                  },
                  "category": { "$ref": "#/components/schemas/Category" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Updated" },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      }
    },
    "/api/assets/analyze-queue": {
      "post": {
        "summary": "Upload and enqueue asset for AI processing",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "image": {
                    "type": "string",
                    "format": "binary"
                  },
                  "category": {
                    "$ref": "#/components/schemas/Category"
                  }
                },
                "required": ["image", "category"]
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "asset": {
                      "allOf": [
                        { "$ref": "#/components/schemas/Asset" },
                        {
                          "type": "object",
                          "properties": {
                            "status": { "type": "string", "enum": ["processing", "draft"] },
                            "fileMetadata": { "$ref": "#/components/schemas/AssetFileMetadata" }
                          }
                        }
                      ]
                    }
                  },
                  "required": ["asset"]
                }
              }
            }
          },
          "400": { "description": "Validation error" },
          "401": { "description": "Unauthorized" }
        }
      }
    },
    "/api/assets/{id}/retry": {
      "post": {
        "summary": "Retry processing for failed/partial asset",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "asset": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string" },
                        "status": { "type": "string", "enum": ["processing"] }
                      },
                      "required": ["id", "status"]
                    }
                  },
                  "required": ["asset"]
                }
              }
            }
          },
          "400": { "description": "Invalid state" },
          "401": { "description": "Unauthorized" },
          "404": { "description": "Not found" }
        }
      }
    }
  }
}
