{
  "openapi": "3.1.0",
  "info": {
    "title": "KLECTR Auth Asset Theme Preferences API",
    "version": "1.1.0",
    "description": "Additive contract for user default asset theme through existing auth profile endpoints. This 1.1.0 change follows semver MINOR policy with backward-compatible optional additions only.",
    "x-contract-evolution": {
      "policy": "semver-minor-additive",
      "compatibility": "backward-compatible",
      "previousVersion": "1.0.0"
    }
  },
  "paths": {
    "/api/auth/me": {
      "get": {
        "summary": "Get current user profile",
        "operationId": "getAuthMeWithAssetTheme",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Authenticated user profile",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserPublic" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      },
      "patch": {
        "summary": "Update current user profile including optional default asset theme",
        "operationId": "patchAuthMeAssetTheme",
        "tags": ["Auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthMePatchRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "User profile updated",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UserPublic" }
              }
            }
          },
          "400": {
            "description": "Validation error (including unknown theme preset)",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": { "description": "Unauthorized" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuthMePatchRequest": {
        "type": "object",
        "properties": {
          "settings": {
            "type": "object",
            "properties": {
              "preferences": {
                "type": "object",
                "properties": {
                  "assetTheme": {
                    "type": "object",
                    "properties": {
                      "defaultThemeId": {
                        "type": ["string", "null"],
                        "description": "Optional preset id. Non-null value must exist in preset catalog; null clears user default theme and falls back to preset vault-graphite."
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "UserPublic": {
        "type": "object",
        "required": ["id", "email"],
        "properties": {
          "id": { "type": "string" },
          "email": { "type": "string", "format": "email" },
          "settings": {
            "type": "object",
            "properties": {
              "preferences": {
                "type": "object",
                "properties": {
                  "assetTheme": {
                    "type": "object",
                    "properties": {
                      "defaultThemeId": { "type": ["string", "null"] }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": true
              }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["success", "error"],
        "properties": {
          "success": { "type": "boolean", "const": false },
          "error": {
            "type": "object",
            "required": ["code", "message"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}
