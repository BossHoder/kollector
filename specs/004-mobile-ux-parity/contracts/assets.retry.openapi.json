{
  "openapi": "3.0.3",
  "info": {
    "title": "Kollector Assets API - Retry (Proposed Amendment)",
    "version": "0.1.0",
    "description": "Proposed contract amendment for Mobile UX Parity: retry a failed/partial asset processing job without creating a new asset."
  },
  "paths": {
    "/api/assets/{id}/retry": {
      "post": {
        "summary": "Retry asset processing",
        "description": "Re-enqueue processing for an existing asset (same asset id).",
        "tags": ["assets"],
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "description": "Asset id (Mongo ObjectId)"
          }
        ],
        "responses": {
          "202": {
            "description": "Accepted - asset processing re-enqueued",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "asset": {
                      "type": "object",
                      "description": "Updated asset (at minimum id + status)",
                      "properties": {
                        "id": { "type": "string" },
                        "status": {
                          "type": "string",
                          "enum": ["processing"]
                        }
                      },
                      "required": ["id", "status"]
                    }
                  },
                  "required": ["asset"]
                }
              }
            }
          },
          "400": { "description": "Bad Request" },
          "401": { "description": "Unauthorized" },
          "403": { "description": "Forbidden" },
          "404": { "description": "Not Found" },
          "409": {
            "description": "Conflict - asset is not in a retryable state"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    }
  }
}
