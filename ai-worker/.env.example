# --- APP ---
PORT=8000
ENVIRONMENT=development

# --- STORAGE ---
# Supported values: local, cloudinary
STORAGE_DRIVER=local
STORAGE_ROOT=./storage
STORAGE_PUBLIC_BASE_URL=http://localhost:3000
# Optional internal URL rewrite for container-to-container downloads.
STORAGE_INTERNAL_BASE_URL=

# --- OPTIONAL CLOUDINARY BACKWARD COMPAT ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- REDIS ---
REDIS_URL=redis://localhost:6379

# --- MODEL CACHE ---
HF_HOME=./.hf-cache
U2NET_HOME=./.u2net

# --- MODELS ---
MODEL_REMOVE_BG=briaai/RMBG-1.4
MODEL_REMOVE_BG_REVISION=
MODEL_VISION=vikhyatk/moondream2
MODEL_VISION_REVISION=
HF_TOKEN=
